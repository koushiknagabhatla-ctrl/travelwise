{
  "name": "travelwise-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install": "npm install",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=frontend",
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
