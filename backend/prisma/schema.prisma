generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  firebaseUid  String    @unique
  name         String
  email        String    @unique
  profilePhoto String?
  createdAt    DateTime  @default(now())
  bookings     Booking[]
}

model Booking {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  pnr          String    @unique
  operatorMode String    // 'flights' | 'trains'
  operatorNo   String
  origin       String
  destination  String
  travelDate   String    // 'YYYY-MM-DD'
  totalFare    Float
  status       String    @default("CONFIRMED")
  seats        Seat[]
  payment      Payment?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([operatorNo])
  @@index([origin, destination])
  @@index([travelDate])
}

model Seat {
  id             String   @id @default(uuid())
  bookingId      String
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seatIdentifier String
  class          String?  // 'Economy' | 'Business' | 'SL'

  @@index([bookingId])
}

model Payment {
  id             String   @id @default(uuid())
  bookingId      String   @unique
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  razorpayTxId   String?
  amount         Float
  status         String   @default("SUCCESS")
  createdAt      DateTime @default(now())
}
